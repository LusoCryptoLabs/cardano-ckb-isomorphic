    }
  let proof = Proof { a: #"b087728e1060c4b66835c985caf98f88df559a98305edda0ef0bdd6200bf1175ec39cf466ee9c5acdd0ac191ab61b0d8", b: #"a900f2745777d4fa6833b703ede2cac72de5b4d90a65324ed834405a6ff97882c7002a933f5f36fe4e15c526e6d41e2d0334a63f97f24e5b135bd53364b301693193989ad93c1e0afc6e7b68ad3c24de597772b7d9fb9a8b64e0f3462a27d976", c: #"a9298817ef3b6659d27a839035fd24e222bae0009ad2b073ea4cf684dfb56dc8cc26a1c2d6d23ef249226871cbbc4c3a" }
