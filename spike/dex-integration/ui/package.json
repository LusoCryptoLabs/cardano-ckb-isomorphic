{
  "name": "bridged-token-dex-ui",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "description": "DEX/JoyID UI for the isomorphic bridge's bridged token - JoyID (CKB xUDT) + Cardano CIP-68 FT, with live caps/pause and MAPPING_SPEC-correct amounts.",
  "scripts": {
