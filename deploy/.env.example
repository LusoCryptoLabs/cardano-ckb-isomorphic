# Chiral dApp - VPS environment (copy to deploy/.env and fill in). Loaded by systemd (EnvironmentFile).
# This is testnet, unaudited, low-value - but the relayer keys still authorize spends, so keep .env + .secrets
# OFF git and chmod 600.

# --- runtime: run the prover/python pipeline via NATIVE bash (no WSL). On a Linux VPS this is auto-on, but set
#     it explicitly so it never falls back to the Windows+WSL path. ---
CHIRAL_NATIVE=1

# repo path as bash / python / the prover ELFs see it == where you put the repo on the VPS.
CHIRAL_REPO_SH=/opt/chiral

PORT=8799
CKB_RPC=https://testnet.ckb.dev

# Blockfrost PREVIEW project id (Cardano testnet). REQUIRED — the dApp surfaces it to the browser for Lucid
# and the python tools read BLOCKFROST_PROJECT_ID. Get one at https://blockfrost.io (Preview network). Never
# commit it; rotate if it leaks. Legacy python scripts read BLOCKFROST_PROJECT_ID; set both to the same value.
BLOCKFROST_PREVIEW=
BLOCKFROST_PROJECT_ID=

# KVM 2 = 2 vCPU -> serve ONE prover at a time (a 2nd concurrent prove would thrash the 8GB box).
PROVE_CONCURRENCY=1

# --- access gate (DoS protection): the prove endpoint runs a 1.39M-constraint Groth16 prove on demand, so it
#     is a DoS magnet. Set a SHARED SECRET and hand testers a link carrying it:  https://host/?t=<token>
#     The dApp strips ?t= into localStorage and sends it as x-chiral-access on heavy calls. Empty = OPEN (dev
#     only - NEVER expose an open instance publicly). Static page + config + health + job-poll stay open so the
#     page always loads. Rotate the token to revoke a cohort. ---
CHIRAL_ACCESS_TOKEN=
# per-IP token bucket on the heavy endpoints (prove/mint/release/return/burn): BURST immediate, then PER_MIN/min.
CHIRAL_RATE_BURST=4
CHIRAL_RATE_PER_MIN=12

# --- E2 stable checkpoint registry: when set, the χADA RETURN re-anchors the ONE already-deployed registry
#     cell IN PLACE (deployed/cardano/preview/ckpt-registry.json) instead of genesis-ing a FRESH checkpoint NFT
#     every return (which churns the escrow + ref scripts ~190 ADA/return). Big win on the return queue; the
#     escrow address + ref scripts then stay constant. Validate with ONE live return after flipping it on. ---
CHIRAL_STABLE_REGISTRY=1

# the deployed amount-binding χCKB mint policy (must match relayer/onchain/zk_chiral_mint.applied.json).
CHI_POLICY_ID=5b4f5525a155fd86757bb3ba20da6e2ef66bcfb72e8853ef31bcf268

# --- keys: place the files under /opt/chiral/.secrets (chmod 600) and point env at them ---
RELAYER_KEY=/opt/chiral/.secrets/pudge_relayer.key            # CKB Pudge relayer (_signer.mjs)
CHIRAL_PREVIEW_KEY=/opt/chiral/.secrets/preview_relayer.key   # Cardano preview, bech32 ed25519_sk (cardano_net.py)
CHIRAL_CARDANO_KEY=/opt/chiral/.secrets/cardano_key.json      # Cardano preview, {sk_hex,...} (Blockfrost CLI tools)

# aiken (validators are rebuilt at release time). Default ~/.aiken/bin/aiken; override if elsewhere.
# AIKEN=/root/.aiken/bin/aiken

# --- warm prover: the resident leap_bound_windowed holds the ~480MB ceremony key so a return proves in ~8s
#     instead of a ~6.7min cold reload. Run it as deploy/chiral-warmprover.service (systemd, auto-restart).
#     The dapp reads CHIRAL_WARM_SOCK to report {"warm":true} on /api/health and xada_burn_orchestrate
#     proves warm-first (cold fallback). The socket path is the convention everywhere (warm_prove.py default).
#     IMPORTANT: CHIRAL_SERVE is set by the warmprover unit ONLY, NOT here - if the dapp inherited CHIRAL_SERVE
#     its cold-fallback prover would enter serve-mode (bind the socket) instead of proving.
CHIRAL_WARM_SOCK=/tmp/chiral_warm.sock
# Optional FORWARD warm prover (resident relay_bind, deploy/chiral-warmprover-forward.service): proveLeap probes
# this socket and proves the forward mint warm-first (~seconds) with a cold fallback. Same CHIRAL_SERVE rule -
# the forward unit sets CHIRAL_SERVE=this path; it is NOT set here. On the 8GB box, see the unit's note about
# not running both warm provers at full size (bake the .uc sidecar + provision swap, or run only the forward one).
RELAY_WARM_SOCK=/tmp/chiral_relay_warm.sock
CEREMONY_PK=/opt/chiral/spike/ckb-to-cardano/circuit/ceremony_xada_burn/leap_bound_windowed_pk.bin
WINDOW_DEPTH=6
CHIRAL_K_MIN=12
# One-off: set CHIRAL_BAKE_UC=1 on the FIRST warm-prover start to write an uncompressed key sidecar (<pk>.uc,
# ~2x disk) so every later start loads in seconds instead of minutes. Remove it once the .uc sidecar exists.
# CHIRAL_BAKE_UC=1
